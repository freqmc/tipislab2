<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.tipislab2.controller.CaesarController"
      spacing="10" style="-fx-padding: 15; -fx-background-color: #f5f5f5;">

    <!-- Заголовок -->
    <Text text="Шифр Цезаря"
          style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>

    <!-- Поле ввода -->
    <VBox spacing="5">
        <Label text="Исходный текст:" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="inputArea" prefHeight="120"
                  wrapText="true"/>
    </VBox>

    <!-- Панель управления сдвигом -->
    <HBox spacing="15" alignment="CENTER">
        <Label text="Сдвиг:" style="-fx-font-weight: bold;"/>
        <Spinner fx:id="shiftSpinner" prefWidth="100"/>
        <Button text="Поменять поля" onAction="#onSwap"
                style="-fx-text-fill: black;"/>
        <Button text="Очистить" onAction="#onClear"
                style="-fx-text-fill: black;"/>
    </HBox>

    <!-- Кнопки действий -->
    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnEncrypt" text="Зашифровать" onAction="#onEncrypt"
                style="-fx-text-fill: black; -fx-font-weight: bold;"/>
        <Button fx:id="btnDecrypt" text="Расшифровать" onAction="#onDecrypt"
                style="-fx-text-fill: black; -fx-font-weight: bold;"/>
        <Button fx:id="btnAutoDecrypt" text="Автоподбор сдвига" onAction="#onAutoDecrypt"
                style="-fx-text-fill: black; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Поле результата -->
    <VBox spacing="5">
        <Label text="Результат:" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="outputArea" prefHeight="120"
                  wrapText="true" editable="false"
                  style="-fx-background-color: #ecf0f1;"/>
    </VBox>
</VBox>